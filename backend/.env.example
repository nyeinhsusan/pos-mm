# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=pos_myanmar
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your_256_bit_random_secret_key_change_this_in_production
JWT_EXPIRATION=24h

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ML Service Configuration
ML_SERVICE_URL=http://localhost:5001
ML_REQUEST_TIMEOUT=5000
ML_RETRY_ATTEMPTS=2
ML_RETRY_DELAY=1000

# Vendor module — SMTP encryption key
# 32-byte (64 hex char) key used to encrypt SMTP credentials at rest in
# the vendor_settings table (AES-256-GCM). Without it, vendor settings
# will refuse to save SMTP creds, but the rest of the app keeps working.
# Generate: openssl rand -hex 32
SMTP_ENCRYPTION_KEY=
